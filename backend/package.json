{
  "name": "pedilivery-backend",
  "version": "1.0.0",
  "description": "Backend MVC para o Pedilivery",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/app.js",
    "start": "node src/app.js",
    "check": "node --check src/app.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.14"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.cjs", "**/?(*.)+(spec|test).cjs"]
  }
}
