{
  "name": "cakeshop-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-full.cjs",
    "dev:frontend": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "start:backend": "npm --prefix backend run start",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "check:backend": "npm --prefix backend run check",
    "test:backend": "npm --prefix backend test",
    "preview": "vite preview",
    "deploy": "npm run build && surge dist karolaynedoces.surge.sh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
